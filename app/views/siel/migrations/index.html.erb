<div class="panel">
	<div class="panel-heading">
		<h3 class="panel-title">Migrations</h3>
	</div>
	<div class="panel-body">
		<div class="pad-btm form-inline">
			<div class="row">
				<div class="col-sm-6 table-toolbar-left">
					<a href="/siel/migrations/create" class="btn btn-success btn-labeled fa fa-plus">Create Migration</a>
				</div>
			</div>
		</div>
		<% if @migrations.length > 0 %>
		<div class="table-responsive">
			<table class="table table-striped table-bordered special">
				<thead>
					<tr>
						<th>Name</th>
						<th>FileName</th>
			
					</tr>
				</thead>
				<tbody>
					<% @migrations.each do |migration| %>
					<tr>
						<td><a class="btn-link"><%=migration[0]%></a></td>
						<td><%=migration[1]%></td>
				
					</tr>
					<% end %>
				</tbody>
			</table>
		</div>
		<% else %>
		<div class="text-center">YOU DON'T HAVE ANY MIGRATION</div>
		<% end %>
		
	</div>
</div>
